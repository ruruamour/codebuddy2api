# CodeBuddy2API service config
CODEBUDDY2API_HOST=127.0.0.1
CODEBUDDY2API_PORT=18182
CODEBUDDY2API_DB_PATH=./data/codebuddy2api.sqlite3
CODEBUDDY2API_API_KEY=
CODEBUDDY2API_ADMIN_KEY=
CODEBUDDY2API_UPSTREAM_URL=https://copilot.tencent.com/v2/chat/completions
CODEBUDDY2API_MODELS=glm-5.1,minimax-m2.7,kimi-k2.6
CODEBUDDY2API_POOL_STRATEGY=round-robin
CODEBUDDY2API_COOLDOWN_SECONDS=300
CODEBUDDY2API_FAILURE_THRESHOLD=3
CODEBUDDY2API_DEFAULT_CONCURRENCY=1
CODEBUDDY2API_REQUEST_TIMEOUT_SECONDS=300
CODEBUDDY2API_CONNECT_TIMEOUT_SECONDS=10
CODEBUDDY2API_LOG_LEVEL=INFO
CODEBUDDY2API_DEBUG_REQUESTS=false
